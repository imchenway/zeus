-fn default_external_agent_home(source: ExternalAgentSource) -> PathBuf {
-    if let Some(home) = std::env::var_os("HOME").or_else(|| std::env::var_os("USERPROFILE")) {
+fn resolve_external_agent_home(
+    codex_home: &Path,
+    source: ExternalAgentSource,
+    override_home: Option<OsString>,
+    user_home: Option<OsString>,
+) -> PathBuf {
+    if let Some(override_home) = override_home {
+        let override_home = PathBuf::from(override_home);
+        return if override_home.is_absolute() {
+            override_home
+        } else {
+            codex_home.join("invalid-zeus-external-agent-home")
+        };
+    }
+
+    if let Some(home) = user_home {
