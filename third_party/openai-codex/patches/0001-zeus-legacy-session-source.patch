+#[test]
+fn resolves_an_absolute_zeus_external_agent_home_override() {
+    let root = TempDir::new().expect("create tempdir");
+    let codex_home = root.path().join(".codex");
+    let zeus_home = root.path().join("Zeus").join("codex-import");
+
+    assert_eq!(
+        resolve_external_agent_home(
+            &codex_home,
+            Some(zeus_home.clone().into_os_string()),
+            Some(root.path().join("user-home").into_os_string()),
+        ),
+        zeus_home,
+    );
+}
+
+#[test]
+fn rejects_a_relative_zeus_external_agent_home_override_without_falling_back_to_claude() {
+    let root = TempDir::new().expect("create tempdir");
+    let codex_home = root.path().join(".codex");
+
+    assert_eq!(
+        resolve_external_agent_home(
+            &codex_home,
+            Some("relative/import-root".into()),
+            Some(root.path().join("user-home").into_os_string()),
+        ),
+        codex_home.join("invalid-zeus-external-agent-home"),
+    );
+}
