diff --git a/codex-rs/external-agent-migration/src/service_tests.rs b/codex-rs/external-agent-migration/src/service_tests.rs
--- a/codex-rs/external-agent-migration/src/service_tests.rs
+++ b/codex-rs/external-agent-migration/src/service_tests.rs
@@ -27,0 +28,49 @@
+#[test]
+fn resolves_an_absolute_zeus_external_agent_home_override() {
+    let root = TempDir::new().expect("create tempdir");
+    let codex_home = root.path().join(".codex");
+    let zeus_home = root.path().join("Zeus").join("codex-import");
+
+    assert_eq!(
+        resolve_external_agent_home(
+            &codex_home,
+            ExternalAgentSource::default(),
+            Some(zeus_home.clone().into_os_string()),
+            Some(root.path().join("user-home").into_os_string()),
+        ),
+        zeus_home,
+    );
+}
+
+#[test]
+fn keeps_the_zeus_override_when_reselecting_the_default_migration_source() {
+    let root = TempDir::new().expect("create tempdir");
+    let codex_home = root.path().join(".codex");
+    let zeus_home = root.path().join("Zeus").join("codex-import");
+
+    assert_eq!(
+        resolve_external_agent_home(
+            &codex_home,
+            ExternalAgentSource::from_migration_source(None),
+            Some(zeus_home.clone().into_os_string()),
+            None,
+        ),
+        zeus_home,
+    );
+}
+
+#[test]
+fn rejects_a_relative_zeus_external_agent_home_override_without_falling_back() {
+    let root = TempDir::new().expect("create tempdir");
+    let codex_home = root.path().join(".codex");
+
+    assert_eq!(
+        resolve_external_agent_home(
+            &codex_home,
+            ExternalAgentSource::default(),
+            Some("relative/import-root".into()),
+            Some(root.path().join("user-home").into_os_string()),
+        ),
+        codex_home.join("invalid-zeus-external-agent-home"),
+    );
+}
